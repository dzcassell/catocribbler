# Cato GraphQL endpoint for the tenant's region.
# Example for a US1 tenant:
# CATO_API_URL=https://api.us1.catonetworks.com/api/v1/graphql2
# Do not guess the regional prefix. Use the endpoint assigned to the tenant.
CATO_API_URL=https://api.<tenant-region>.catonetworks.com/api/v1/graphql2

# Numeric Cato tenant/account ID. Do not use the display name.
CATO_ACCOUNT_ID=<numeric-cato-account-id>

# In-container Docker secret path. Normally leave this unchanged.
CATO_API_KEY_FILE=/run/secrets/cato_api_key

# Cribl Worker, load balancer, or VIP reachable from inside the container.
# Do not use 127.0.0.1 unless Cribl is inside this same container.
CRIBL_SYSLOG_HOST=<cribl-worker-or-vip-fqdn>

# TCP port on the Cribl Syslog Source.
CRIBL_SYSLOG_PORT=9514

# Use true for TLS and false only for a trusted lab network.
CRIBL_SYSLOG_TLS=true

# DNS name expected in the Cribl TLS certificate.
# For non-TLS deployments this value is ignored.
CRIBL_SYSLOG_SERVER_NAME=<cribl-certificate-server-name>

# In-container Docker secret path containing the PEM CA chain.
# Normally leave this unchanged. The source file must exist even when TLS is false.
CRIBL_SYSLOG_CA_FILE=/run/secrets/cribl_ca.pem

# Delay after a non-full EventsFeed page. Full 3,000-event pages are drained immediately.
POLL_INTERVAL_SECONDS=30

# Persistent marker path inside the container. Normally leave this unchanged.
STATE_FILE=/state/marker.txt

# Python logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Hostname placed in the RFC 5424 syslog envelope.
SYSLOG_HOSTNAME=cato-events-poller
