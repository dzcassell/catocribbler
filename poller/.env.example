# UNSUPPORTED, NON-PRODUCTION DEMONSTRATION CONFIGURATION ONLY.
#
# This repository is not supported by Damon Cassell, Cato Networks, Cribl,
# any employer, contributor, vendor, partner, or anyone else. It is not an
# official integration. There is no license grant, warranty, maintenance
# commitment, compatibility promise, or obligation to assist.
#
# Do not use this configuration with production systems, credentials, data,
# networks, Cribl Worker Groups, or Destinations. Read ../DISCLAIMER.md.

# Cato GraphQL endpoint for the approved test tenant's region.
# Example for a US1 tenant:
# CATO_API_URL=https://api.us1.catonetworks.com/api/v1/graphql2
# Do not guess the regional prefix. Use the endpoint assigned to the test tenant.
CATO_API_URL=https://api.<tenant-region>.catonetworks.com/api/v1/graphql2

# Numeric Cato test tenant/account ID. Do not use the display name.
CATO_ACCOUNT_ID=<numeric-cato-account-id>

# In-container Docker secret path. Normally leave unchanged.
CATO_API_KEY_FILE=/run/secrets/cato_api_key

# Existing NON-PRODUCTION Cribl Docker environment:
#
# Host-published-port model:
#   Use the Docker test host's LAN IP or DNS name.
#   Example: CRIBL_SYSLOG_HOST=192.0.2.25
#
# Shared-external-network model:
#   Attach this Compose project only to an isolated Cribl test network with
#   compose.override.yaml, then use the Cribl service/container DNS name.
#   Example: CRIBL_SYSLOG_HOST=cribl-worker
#
# Do not use localhost or 127.0.0.1. Inside this container, those addresses
# refer to the demonstration poller itself, not Cribl or the Docker host.
CRIBL_SYSLOG_HOST=<existing-non-production-cribl-host-or-container-name>

# TCP port on the non-production Cribl Syslog Source.
CRIBL_SYSLOG_PORT=9514

# Use true for an approved TLS test. Use false only in an isolated lab.
# TLS does not make this code production-ready.
CRIBL_SYSLOG_TLS=true

# DNS name expected in the test Cribl certificate.
# This can differ from CRIBL_SYSLOG_HOST when connecting by IP or container name.
# Ignored when CRIBL_SYSLOG_TLS=false.
CRIBL_SYSLOG_SERVER_NAME=<cribl-test-certificate-server-name>

# In-container Docker secret path containing the PEM CA chain that validates
# the test Cribl server certificate. Normally leave unchanged.
# The host source file must exist even when TLS is disabled.
CRIBL_SYSLOG_CA_FILE=/run/secrets/cribl_ca.pem

# Delay after a non-full EventsFeed page. Full 3,000-event pages are drained
# immediately and can create unexpected volume, duplicates, cost, or overload.
POLL_INTERVAL_SECONDS=30

# Persistent Cato EventsFeed demonstration marker path inside the container.
# Do not share, edit, publish, or assume a fixed marker length.
STATE_FILE=/state/marker.txt

# Python logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
# Logs can contain tenant context. Use DEBUG only in an isolated test.
LOG_LEVEL=INFO

# Hostname placed in the RFC 5424 envelope sent to the test Cribl Source.
SYSLOG_HOSTNAME=cato-events-poller
